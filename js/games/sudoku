var sudokuGrid,sudokuSelected,sudokuSolution,sudokuScore,sudokuMistakes;
function startSudoku(){openGameScreen('🧩 Sudoku');gameCanvas.style.display='none';sudokuGrid=[[5,3,0,0,7,0,0,0,0],[6,0,0,1,9,5,0,0,0],[0,9,8,0,0,0,0,6,0],[8,0,0,0,6,0,0,0,3],[4,0,0,8,0,3,0,0,1],[7,0,0,0,2,0,0,0,6],[0,6,0,0,0,0,2,8,0],[0,0,0,4,1,9,0,0,5],[0,0,0,0,8,0,0,7,9]];sudokuSelected=null;sudokuScore=0;sudokuMistakes=0;var d=document.createElement('div');d.id='sudokuContainer';d.style.cssText='flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px;overflow-y:auto';renderSudoku(d);gameCanvas.parentNode.insertBefore(d,gameCanvas);currentGameRestart=startSudoku;}
function renderSudoku(d){var h='<h2 style="color:#D4AF37;margin-bottom:8px;text-align:center">🧩 Sudoku</h2>';h+='<div style="display:flex;justify-content:center;gap:15px;margin-bottom:8px;font-size:12px;color:rgba(255,255,255,0.6)"><span>Mistakes: <b style="color:#FF4757">'+sudokuMistakes+'</b>/3</span></div>';h+='<div style="display:grid;grid-template-columns:repeat(9,1fr);gap:1.5px;max-width:340px;background:#D4AF37;padding:2px;border-radius:10px">';for(var r=0;r<9;r++){for(var c=0;c<9;c++){var v=sudokuGrid[r][c];var isSelected=sudokuSelected&&sudokuSelected.r===r&&sudokuSelected.c===c;var isOriginal=v!==0;var bg=isSelected?'rgba(212,175,55,0.4)':isOriginal?'rgba(255,255,255,0.08)':'#0A0E27';h+='<div style="aspect-ratio:1;background:'+bg+';display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:bold;color:'+(isOriginal?'#D4AF37':'#fff')+';cursor:pointer;border-right:'+(c%3===2&&c<8?'1.5px solid #D4AF37':'')+';border-bottom:'+(r%3===2&&r<8?'1.5px solid #D4AF37':'')+'" onclick="selectSudokuCell('+r+','+c+')">'+(v||'')+'</div>';}}h+='</div>';h+='<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:5px;max-width:340px;margin-top:10px">';for(var i=1;i<=9;i++){h+='<button class="btn" style="padding:10px;font-size:15px;margin:0" onclick="inputSudokuNumber('+i+')">'+i+'</button>';}h+='<button class="btn-out" style="padding:10px;font-size:11px;margin:0" onclick="inputSudokuNumber(0)">✕</button>';h+='</div>';h+='<button class="btn-out" onclick="closeGameScreen()" style="margin-top:10px">Exit</button>';d.innerHTML=h;}
function selectSudokuCell(r,c){sudokuSelected={r:r,c:c};renderSudoku(document.getElementById('sudokuContainer'));}
function inputSudokuNumber(n){if(!sudokuSelected)return;var r=sudokuSelected.r,c=sudokuSelected.c;if(sudokuGrid[r][c]!==0&&n!==0)return;sudokuGrid[r][c]=n;if(n>0){if(!isValidSudoku(r,c,n)){sudokuMistakes++;if(sudokuMistakes>=3){endGame('🧩 Game Over! 3 mistakes');return;}}else{sudokuScore+=10;updateGameScore(sudokuScore);}}renderSudoku(document.getElementById('sudokuContainer'));if(isSudokuComplete()){endGame('🎉 Sudoku Solved! Score: '+sudokuScore);}}
function isValidSudoku(r,c,n){for(var i=0;i<9;i++){if(i!==c&&sudokuGrid[r][i]===n)return false;if(i!==r&&sudokuGrid[i][c]===n)return false;}var br=Math.floor(r/3)*3,bc=Math.floor(c/3)*3;for(var i=br;i<br+3;i++)for(var j=bc;j<bc+3;j++)if((i!==r||j!==c)&&sudokuGrid[i][j]===n)return false;return true;}
function isSudokuComplete(){for(var r=0;r<9;r++)for(var c=0;c<9;c++)if(sudokuGrid[r][c]===0)return false;return true;}
